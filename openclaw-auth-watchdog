#!/bin/bash
# openclaw-auth-watchdog
# Runs every 15 min. Checks and repairs openclaw auth config, proxy token, and cooldown state.
# REPAIRED=1 means auth files were patched (does NOT restart gateway on its own).
# GATEWAY_NEEDS_RESTART=1 means the gateway is actually unresponsive and needs a kick.
# Separating these prevents unnecessary gateway restarts for routine auth file repairs.

CONFIG="$HOME/.openclaw/openclaw.json"
PLIST="$HOME/Library/LaunchAgents/ai.openclaw.gateway.plist"
LOG="/tmp/openclaw-auth-watchdog.log"
REPAIRED=0
GATEWAY_NEEDS_RESTART=0
NODE="${NODE:-$(command -v node)}"
if [ -z "$NODE" ]; then
  log "ERROR: node not found in PATH"
  exit 1
fi
AUTH_PROFILES="$HOME/.openclaw/agents/main/agent/auth-profiles.json"

log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG"
}

# Run a node script from a string, passing $1 as process.argv[1].
# Uses a temp file to avoid stdin dependency (heredoc breaks when stdin is unavailable,
# e.g. when called via execFile from the Telegram trigger).
run_node() {
  local script="$1"
  local arg="$2"
  local tmp
  tmp=$(mktemp /tmp/watchdog-node-XXXXXX.js)
  echo "$script" > "$tmp"
  "$NODE" "$tmp" "$arg"
  local rc=$?
  rm -f "$tmp"
  return $rc
}

if [ ! -f "$CONFIG" ]; then
  log "ERROR: openclaw.json not found at $CONFIG"
  exit 1
fi

# ── Check 1: plist env vars ──────────────────────────────────────────────────
if [ -f "$PLIST" ]; then
  MISSING_VARS=""
  grep -q "ANTHROPIC_API_KEY" "$PLIST" || MISSING_VARS="$MISSING_VARS ANTHROPIC_API_KEY"
  grep -q "ANTHROPIC_BASE_URL" "$PLIST" || MISSING_VARS="$MISSING_VARS ANTHROPIC_BASE_URL"

  if [ -n "$MISSING_VARS" ]; then
    log "WARNING: plist missing env vars:$MISSING_VARS — restoring"
    run_node '
const fs = require("fs");
const path = process.argv[1];
let content = fs.readFileSync(path, "utf8");
const vars = { ANTHROPIC_API_KEY: "claude-max-proxy", ANTHROPIC_BASE_URL: "http://127.0.0.1:4523" };
for (const [key, value] of Object.entries(vars)) {
  if (!content.includes("<key>" + key + "</key>")) {
    content = content.replace("</dict>\n</dict>", "    <key>" + key + "</key>\n    <string>" + value + "</string>\n    </dict>\n</dict>");
    console.log("Added " + key);
  }
}
fs.writeFileSync(path, content);
' "$PLIST"
    REPAIRED=1
  else
    log "OK: plist env vars present"
  fi
fi

# ── Check 2: openclaw.json auth profile ──────────────────────────────────────
if grep -q '"anthropic:claude-cli"' "$CONFIG"; then
  log "OK: anthropic:claude-cli profile present"
else
  log "WARNING: anthropic:claude-cli profile missing — restoring"
  run_node '
const fs = require("fs");
const path = process.argv[1];
const config = JSON.parse(fs.readFileSync(path, "utf8"));
if (!config.auth) config.auth = {};
if (!config.auth.profiles) config.auth.profiles = {};
config.auth.profiles["anthropic:claude-cli"] = { provider: "anthropic", mode: "oauth" };
const profiles = { "anthropic:claude-cli": config.auth.profiles["anthropic:claude-cli"] };
for (const [k, v] of Object.entries(config.auth.profiles)) {
  if (k !== "anthropic:claude-cli") profiles[k] = v;
}
config.auth.profiles = profiles;
delete config.auth.profiles["anthropic:default"];
delete config.auth.profiles["anthropic:manual"];
fs.writeFileSync(path, JSON.stringify(config, null, 2));
console.log("Patched: anthropic:claude-cli restored");
' "$CONFIG"
  REPAIRED=1
fi

# ── Check 3a: sync token from credentials.json → auth-profiles.json ──────────
CREDS_FILE="$HOME/.claude/.credentials.json"
if [ -f "$AUTH_PROFILES" ] && [ -f "$CREDS_FILE" ]; then
  TOKEN_IN_SYNC=$("$NODE" -e "
    const fs = require('fs'), os = require('os');
    const creds = JSON.parse(fs.readFileSync('$CREDS_FILE','utf8'));
    const profiles = JSON.parse(fs.readFileSync('$AUTH_PROFILES','utf8'));
    const credsToken = creds?.claudeAiOauth?.accessToken || '';
    const profileToken = profiles?.profiles?.['anthropic:claude-cli']?.access || '';
    console.log(credsToken && credsToken === profileToken ? 'yes' : 'no');
  " 2>/dev/null)

  if [ "$TOKEN_IN_SYNC" = "yes" ]; then
    log "OK: auth-profiles.json token matches credentials.json"
  else
    log "WARNING: auth-profiles.json token out of sync with credentials.json — syncing"
    run_node '
const fs = require("fs");
const os = require("os");
const path = process.argv[1];
const data = JSON.parse(fs.readFileSync(path, "utf8"));
const creds = JSON.parse(fs.readFileSync(os.homedir() + "/.claude/.credentials.json", "utf8"));
const oauth = creds.claudeAiOauth;
if (oauth && oauth.accessToken && data.profiles && data.profiles["anthropic:claude-cli"]) {
  data.profiles["anthropic:claude-cli"].access = oauth.accessToken;
  data.profiles["anthropic:claude-cli"].refresh = oauth.refreshToken;
  data.profiles["anthropic:claude-cli"].expires = Date.now() + 365 * 24 * 60 * 60 * 1000;
  fs.writeFileSync(path, JSON.stringify(data, null, 2));
  console.log("Synced token from credentials.json into auth-profiles");
} else {
  console.log("Nothing to sync (missing fields)");
}
' "$AUTH_PROFILES"
    REPAIRED=1
  fi
fi

# ── Check 3: auth-profiles.json order, expiry, cooldown ──────────────────────
if [ -f "$AUTH_PROFILES" ]; then
  FIRST_PROFILE=$("$NODE" -e "
    const p = JSON.parse(require('fs').readFileSync('$AUTH_PROFILES','utf8'));
    const order = p.order && p.order.anthropic;
    console.log(order && order[0] || '');
  " 2>/dev/null)

  CLAUDE_CLI_EXPIRED=$("$NODE" -e "
    const p = JSON.parse(require('fs').readFileSync('$AUTH_PROFILES','utf8'));
    const exp = p.profiles && p.profiles['anthropic:claude-cli'] && p.profiles['anthropic:claude-cli'].expires;
    console.log(!exp || exp < Date.now() ? 'yes' : 'no');
  " 2>/dev/null)

  CLAUDE_CLI_COOLDOWN=$("$NODE" -e "
    const p = JSON.parse(require('fs').readFileSync('$AUTH_PROFILES','utf8'));
    const stats = p.usageStats && p.usageStats['anthropic:claude-cli'];
    console.log(stats && stats.cooldownUntil && stats.cooldownUntil > Date.now() ? 'yes' : 'no');
  " 2>/dev/null)

  if [ "$FIRST_PROFILE" = "anthropic:claude-cli" ] && [ "$CLAUDE_CLI_EXPIRED" != "yes" ] && [ "$CLAUDE_CLI_COOLDOWN" != "yes" ]; then
    log "OK: auth-profiles.json order, expiry, and cooldown are correct"
  else
    [ "$FIRST_PROFILE" != "anthropic:claude-cli" ] && log "WARNING: auth-profiles.json order wrong (first: '$FIRST_PROFILE') — restoring"
    [ "$CLAUDE_CLI_EXPIRED" = "yes" ] && log "WARNING: auth-profiles.json claude-cli token expired — extending"
    [ "$CLAUDE_CLI_COOLDOWN" = "yes" ] && log "WARNING: auth-profiles.json claude-cli in cooldown — clearing"
    run_node '
const fs = require("fs");
const path = process.argv[1];
const data = JSON.parse(fs.readFileSync(path, "utf8"));
if (!data.order) data.order = {};
data.order.anthropic = ["anthropic:claude-cli"];
if (!data.lastGood) data.lastGood = {};
data.lastGood.anthropic = "anthropic:claude-cli";
if (data.profiles && data.profiles["anthropic:claude-cli"]) {
  data.profiles["anthropic:claude-cli"].expires = Date.now() + 365 * 24 * 60 * 60 * 1000;
}
if (data.usageStats && data.usageStats["anthropic:claude-cli"]) {
  delete data.usageStats["anthropic:claude-cli"].cooldownUntil;
  delete data.usageStats["anthropic:claude-cli"].cooldownReason;
  data.usageStats["anthropic:claude-cli"].errorCount = 0;
  delete data.usageStats["anthropic:claude-cli"].failureCounts;
}
fs.writeFileSync(path, JSON.stringify(data, null, 2));
console.log("Patched: auth-profiles.json order, expiry, and cooldown restored");
' "$AUTH_PROFILES"
    REPAIRED=1
  fi
fi

# ── Check if gateway is responsive ──────────────────────────────────────────
GATEWAY_STATUS=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 http://127.0.0.1:18789/health 2>/dev/null)
if [ "$GATEWAY_STATUS" = "200" ] || [ "$GATEWAY_STATUS" = "401" ]; then
  GATEWAY_ALIVE=1
  log "OK: gateway responding (HTTP $GATEWAY_STATUS)"
else
  GATEWAY_ALIVE=0
  GATEWAY_NEEDS_RESTART=1
  log "WARNING: gateway not responding (HTTP $GATEWAY_STATUS) — will restart"
fi

# ── Restart gateway only if it is actually unresponsive ──────────────────────
# Auth file repairs (REPAIRED=1) do NOT require a gateway restart — the gateway
# picks up config changes on its own. Only restart when the process is dead/hung.
if [ "$GATEWAY_NEEDS_RESTART" -eq 1 ]; then
  log "Restarting gateway (was unresponsive)"
  launchctl bootout gui/$UID/ai.openclaw.gateway 2>/dev/null
  sleep 2
  launchctl bootstrap gui/$UID "$PLIST" 2>/dev/null
  sleep 3
  REPAIRED=1
elif [ "$REPAIRED" -eq 1 ]; then
  log "Auth files repaired — gateway left running (no restart needed)"
else
  log "OK: gateway healthy, no restart needed"
fi

# ── Alert if repairs were made ────────────────────────────────────────────────
if [ "$REPAIRED" -eq 1 ]; then
  log "Repairs made — gateway $([ "$GATEWAY_NEEDS_RESTART" -eq 1 ] && echo 'restarted' || echo 'left running')"

  CLAWDBOT="$HOME/.openclaw/clawdbot.json"
  if [ -f "$CLAWDBOT" ]; then
    BOT_TOKEN=$("$NODE" -e "
      const d = JSON.parse(require('fs').readFileSync('$CLAWDBOT','utf8'));
      console.log(d?.channels?.telegram?.botToken || '');
    " 2>/dev/null)
    CHAT_ID=$(cat "$HOME/.openclaw/credentials/telegram-allowFrom.json" 2>/dev/null | "$NODE" -e "
      const d = JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
      console.log(d?.allowFrom?.[0] || Array.isArray(d) ? d[0] : d || '');
    " 2>/dev/null)
    if [ -n "$BOT_TOKEN" ] && [ -n "$CHAT_ID" ]; then
      curl -s -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
        -d "chat_id=$CHAT_ID" \
        -d "text=⚠️ openclaw-auth-watchdog auto-repaired config. Gateway restarted." \
        > /dev/null
      log "Telegram alert sent"
    fi
  fi
fi

# ── Proactive token refresh + validity check ─────────────────────────────────
PROXY_URL="http://127.0.0.1:4523"
HEALTH=$(curl -s --max-time 5 "$PROXY_URL/health" 2>/dev/null)

if echo "$HEALTH" | grep -q '"token":"valid"'; then
  log "Proxy health: token valid"

  TEST_BODY='{"model":"claude-haiku-4-5-20251001","max_tokens":1,"messages":[{"role":"user","content":"1"}]}'
  TEST_STATUS=$(curl -s -o /dev/null -w "%{http_code}" --max-time 15 \
    -X POST "$PROXY_URL/v1/messages" \
    -H "content-type: application/json" \
    -H "x-api-key: claude-max-proxy" \
    -H "anthropic-version: 2023-06-01" \
    -d "$TEST_BODY" 2>/dev/null)

  if [ "$TEST_STATUS" = "200" ]; then
    log "Proxy token: Anthropic accepted (HTTP 200)"
  elif [ "$TEST_STATUS" = "401" ]; then
    log "WARNING: Anthropic rejected token (HTTP 401) — forcing refresh"
    REFRESH_RESULT=$(curl -s --max-time 15 -X POST "$PROXY_URL/force-refresh" 2>/dev/null)
    if echo "$REFRESH_RESULT" | grep -q '"status":"ok"'; then
      log "Token force-refreshed: $REFRESH_RESULT"
      if [ -f "$AUTH_PROFILES" ]; then
        run_node '
const fs = require("fs");
const os = require("os");
const path = process.argv[1];
const data = JSON.parse(fs.readFileSync(path, "utf8"));

// Sync fresh token from credentials.json into auth-profiles
const credsPath = os.homedir() + "/.claude/.credentials.json";
try {
  const creds = JSON.parse(fs.readFileSync(credsPath, "utf8"));
  const oauth = creds.claudeAiOauth;
  if (oauth && oauth.accessToken && data.profiles && data.profiles["anthropic:claude-cli"]) {
    data.profiles["anthropic:claude-cli"].access = oauth.accessToken;
    data.profiles["anthropic:claude-cli"].refresh = oauth.refreshToken;
    data.profiles["anthropic:claude-cli"].expires = Date.now() + 365 * 24 * 60 * 60 * 1000;
    console.log("Synced fresh token from credentials.json into auth-profiles");
  }
} catch(e) { console.log("Could not sync token from credentials:", e.message); }

// Clear cooldown
if (data.usageStats && data.usageStats["anthropic:claude-cli"]) {
  delete data.usageStats["anthropic:claude-cli"].cooldownUntil;
  delete data.usageStats["anthropic:claude-cli"].cooldownReason;
  data.usageStats["anthropic:claude-cli"].errorCount = 0;
  delete data.usageStats["anthropic:claude-cli"].failureCounts;
}
fs.writeFileSync(path, JSON.stringify(data, null, 2));
console.log("Cleared openclaw cooldown after token refresh");
' "$AUTH_PROFILES"
        log "Synced token and cleared openclaw auth cooldown"
      fi
      REPAIRED=1
    else
      log "ERROR: Force refresh failed: $REFRESH_RESULT"
    fi
  else
    log "WARNING: proxy test request returned HTTP $TEST_STATUS"
  fi
elif echo "$HEALTH" | grep -q '"token"'; then
  log "WARNING: proxy token state — $HEALTH"
else
  log "WARNING: proxy not responding at $PROXY_URL"
fi

log "Done"
